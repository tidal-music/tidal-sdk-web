{
  "name": "@tidal-music/true-time",
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare": "vite build",
    "build": "vite build",
    "build:dev": "vite build -m development",
    "clean": "rm -rf coverage dist .eslintcache",
    "typecheck": "tsc && tsc -p tsconfig.build.json",
    "check:types-resolution": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
    "lint": "eslint . --cache --cache-strategy content",
    "lint:ci": "eslint . --quiet",
    "lint:fix": "pnpm run lint --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "pnpm run test --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "4.1.7",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-dts": "5.0.1",
    "vitest": "4.1.7"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "ssh://git@github.com:tidal-music/tidal-sdk-web.git"
  },
  "license": "Apache-2.0",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    "types": "./dist/src/index.d.ts",
    "import": "./dist/index.js",
    "default": "./dist/index.js"
  }
}
