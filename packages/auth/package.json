{
  "name": "@tidal-music/auth",
  "version": "1.6.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "ssh://git@github.com:tidal-music/tidal-sdk-web.git"
  },
  "license": "Apache-2.0",
  "module": "dist/index.js",
  "exports": {
    "types": "./dist/src/index.d.ts",
    "import": "./dist/index.js",
    "default": "./dist/index.js"
  },
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build -m development",
    "clean": "rm -rf coverage dist .eslintcache",
    "dev": "vite --debug --cors -c=./vite.config.ts",
    "lint": "eslint . --cache --cache-strategy content",
    "lint:ci": "eslint . --quiet",
    "lint:fix": "pnpm run lint --fix",
    "prepare": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "pnpm run test --coverage",
    "test:ui": "pnpm run test:coverage --ui",
    "typecheck": "tsc",
    "check:types-resolution": "attw --pack . --ignore-rules=cjs-resolves-to-esm"
  },
  "dependencies": {
    "@tidal-music/common": "workspace:^",
    "@tidal-music/true-time": "workspace:^"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "4.1.7",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vite-plugin-dts": "5.0.1",
    "vitest": "4.1.7"
  }
}
