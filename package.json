{
  "name": "@tidal-music/tidal-sdk-web",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs": "typedoc",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "lint:ci": "pnpm -r lint:ci",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test --run",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "generateTypes": "pnpm -r generateTypes"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "eslint": "10.2.1",
    "eslint-config-tidal": "5.0.0",
    "eslint-plugin-disable-autofix": "6.1.1",
    "eslint-plugin-jsdoc": "62.9.0",
    "typedoc": "0.28.19",
    "vite": "8.0.8",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-package-version": "1.1.0",
    "vitest": "4.1.4"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "cypress"
    ],
    "overrides": {
      "serialize-javascript": "7.0.5",
      "koa": "3.2.0",
      "basic-ftp": "5.2.1",
      "rollup@>=4": "4.60.1",
      "ajv@>=8": "8.18.0",
      "lodash": "4.18.1",
      "minimatch@<4": "3.1.5",
      "minimatch@>=5": "10.2.5",
      "flatted": "3.4.2",
      "diff@>=5 <6": "8.0.4",
      "diff@>=8": "8.0.4",
      "markdown-it@>=14": "14.1.1",
      "js-yaml@>=4": "4.1.1",
      "qs@>=6.7": "6.15.1",
      "tar-fs@>=3": "3.1.2",
      "micromatch": "4.0.8",
      "@75lb/deep-merge": "1.1.3"
    }
  }
}
