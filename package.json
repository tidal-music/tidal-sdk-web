{
  "name": "@tidal-music/tidal-sdk-web",
  "packageManager": "pnpm@11.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "docs": "typedoc",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "lint:ci": "pnpm -r lint:ci",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test --run",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "check:types-resolution": "pnpm -r --workspace-concurrency=1 --filter='!@tidal-music/template' check:types-resolution",
    "generateTypes": "pnpm -r generateTypes"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@eslint/compat": "2.1.0",
    "eslint": "10.4.0",
    "eslint-config-tidal": "5.0.0",
    "eslint-plugin-disable-autofix": "6.1.1",
    "eslint-plugin-jsdoc": "62.9.0",
    "typedoc": "0.28.19",
    "vite": "8.0.14",
    "vite-plugin-dts": "5.0.1",
    "vite-plugin-mkcert": "2.0.0",
    "vite-plugin-package-version": "1.1.0",
    "vitest": "4.1.7"
  }
}
