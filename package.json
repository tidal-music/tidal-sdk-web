{
  "name": "@tidal-music/tidal-sdk-web",
  "packageManager": "pnpm@10.31.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs": "typedoc",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "lint:ci": "pnpm -r lint:ci",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test --run",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "generateTypes": "pnpm -r generateTypes"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "eslint": "10.0.3",
    "eslint-config-tidal": "5.0.0",
    "eslint-plugin-disable-autofix": "5.0.1",
    "eslint-plugin-jsdoc": "62.7.1",
    "typedoc": "0.28.17",
    "vitest": "4.0.18"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "cypress"
    ],
    "overrides": {
      "serialize-javascript": "7.0.4",
      "koa": "3.1.2",
      "basic-ftp": "5.2.0",
      "rollup@>=4": "4.59.0",
      "ajv@>=8": "8.18.0",
      "lodash": "4.17.23",
      "minimatch@<4": "3.1.5",
      "minimatch@>=5 <6": "5.1.9",
      "minimatch@>=9 <10": "9.0.9",
      "minimatch@>=10": "10.2.4",
      "diff@>=5 <6": "5.2.2",
      "diff@>=8": "8.0.3",
      "markdown-it@>=14": "14.1.1",
      "js-yaml@>=4": "4.1.1",
      "qs@>=6.7": "6.15.0",
      "tar-fs@>=3": "3.1.2",
      "brace-expansion@>=2 <3": "2.0.2",
      "micromatch": "4.0.8",
      "@75lb/deep-merge": "1.1.3"
    }
  }
}
